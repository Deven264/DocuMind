{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "dev:app": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && npm run electron:dev\"",
    "python:dev": "cd ../backend && .\\venv\\Scripts\\python.exe -m uvicorn main:app --reload",
    "dev:all": "concurrently -k \"npm run python:dev\" \"npm run dev:app\""
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.0.0",
    "wait-on": "^9.0.5"
  }
}
